MNEMONIC="twelve or twenty four word bip39 mnemonic here"

# Tendermint / CometBFT JSON-RPC endpoint (for broadcasting)
RPC_URL=https://rpc.tsc.example/

# Cosmos SDK REST (LCD) endpoint (for account/sequence queries)
REST_URL=https://rest.tsc.example

CHAIN_ID=tsc_8878788-1
BECH32_PREFIX=tsc
DENOM=aTSC

# Pubkey type URL for eth_secp256k1 on this chain. Common values:
#   /cosmos.evm.crypto.v1.ethsecp256k1.PubKey   (cosmos-evm)
#   /ethermint.crypto.v1.ethsecp256k1.PubKey    (legacy ethermint)
ETH_PUBKEY_TYPE_URL=/cosmos.evm.crypto.v1.ethsecp256k1.PubKey

# Default fee (in aTSC) and gas limit for example txs
FEE_AMOUNT=20000000000000000
GAS_LIMIT=300000
